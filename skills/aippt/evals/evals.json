{
  "skill_name": "aippt",
  "schema_version": "3.0.0",
  "evals": [
    {
      "id": "workflow-01-generic-company-deck",
      "category": "positive",
      "prompt": "帮我做一套新的企业介绍 PPT，主题是 Dify 企业版介绍。受众是潜在客户，需要从官网和最近产品更新整理成完整的新 deck。",
      "should_trigger": true,
      "scene_id": "company-intro",
      "should_use_subskill": true,
      "required_artifacts": [
        "brand_profile",
        "brief_summary",
        "research_dossier",
        "outline",
        "slide_spec",
        "page_plan",
        "style_profile",
        "delivery_manifest"
      ],
      "route_assertions": [
        "scene pack is loaded before generic AIPPT",
        "outline.approved remains false before approval"
      ]
    },
    {
      "id": "workflow-02-generic-new-deck",
      "category": "positive",
      "prompt": "帮我做一套新的 AI 产品战略 deck，从我提供的会议纪要和白皮书出发，完整输出 research、提纲、逐页规划和交付清单。",
      "should_trigger": true,
      "scene_id": "generic",
      "should_use_subskill": false,
      "required_artifacts": [
        "brief_summary",
        "research_dossier",
        "outline",
        "slide_spec",
        "page_plan",
        "style_profile",
        "delivery_manifest"
      ]
    },
    {
      "id": "workflow-03-svg-mode",
      "category": "positive",
      "prompt": "从零做一套新的行业研究 deck，最后需要 SVG 页面和 preview，资料来源要可追溯。",
      "should_trigger": true,
      "scene_id": "generic",
      "should_use_subskill": false,
      "required_validations": [
        "validate-artifacts passes",
        "validate-svg passes"
      ],
      "route_assertions": [
        "style_instruction_block is present in style_profile",
        "layout_hint is reflected in slide contracts"
      ]
    },
    {
      "id": "workflow-04-preferences-and-staged-modes",
      "category": "positive",
      "prompt": "使用我的默认配置做一套新的产品介绍 deck，先停在 outline_only，确认风格和结构后再继续。",
      "should_trigger": true,
      "scene_id": "generic",
      "should_use_subskill": false,
      "required_artifacts": [
        "outline"
      ],
      "route_assertions": [
        "preferences are recorded in project metadata",
        "outline_only does not bypass approval gates"
      ]
    },
    {
      "id": "workflow-05-partial-regeneration-contract",
      "category": "positive",
      "prompt": "这套新 deck 已经批准过 outline，请只重建 S03 和 S04 的 prompt bundle，并保留其他页不动。",
      "should_trigger": true,
      "scene_id": "generic",
      "should_use_subskill": false,
      "route_assertions": [
        "partial regeneration stays inside generated artifacts",
        "delivery_manifest records the regenerated slide ids"
      ]
    },
    {
      "id": "scene-01-company-intro-positive",
      "category": "positive",
      "prompt": "请从零开始做一套企业介绍 deck，给潜在客户看，重点讲公司定位、产品方案、客户证明和部署模式。",
      "should_trigger": true,
      "scene_id": "company-intro",
      "should_use_subskill": true,
      "scene_assertions": [
        "required_sections reflected in outline",
        "review_bias reflected in slide_spec.review_focus"
      ]
    },
    {
      "id": "scene-01-company-intro-negative",
      "category": "negative",
      "prompt": "我已经有公司介绍 PPTX，只想改第 3 页和第 4 页的排版。",
      "should_trigger": false,
      "scene_id": "company-intro",
      "should_use_subskill": false,
      "expected_routing": "pptx-editing"
    },
    {
      "id": "scene-02-investor-pitch-positive",
