{
  "skill_name": "aippt",
  "schema_version": "2.0.0",
  "evals": [
    {
      "id": "workflow-01-company-intro",
      "category": "positive",
      "prompt": "帮我做一套新的企业介绍 PPT，主题是“Dify 企业版介绍”，受众是潜在客户。需要 12 页左右，风格偏商务科技。可以参考官网和最近的产品更新。",
      "should_trigger": true,
      "required_artifacts": [
        "brand_profile",
        "brief_summary",
        "research_dossier",
        "outline",
        "slide_spec",
        "page_plan",
        "style_profile",
        "delivery_manifest"
      ],
      "required_outline_fields": [
        "governing_thought",
        "engagement_archetype",
        "pillar_map",
        "transition_map",
        "quality_gates",
        "slides[].argument_claim",
        "slides[].proof_question"
      ],
      "required_slide_spec_fields": [
        "slides[].argument_claim",
        "slides[].proof_question",
        "slides[].exhibit_intent",
        "slides[].evidence_layer",
        "slides[].data_requirements",
        "slides[].fit_risk"
      ],
      "required_page_plan_fields": [
        "slides[].proof_trace",
        "slides[].exhibit_blueprint",
        "slides[].rhythm_slot",
        "slides[].adjacency_check",
        "slides[].overflow_decision"
      ],
      "required_validations": [
        "validate-artifacts passes"
      ]
    },
    {
      "id": "workflow-02-investor-pitch",
      "category": "positive",
      "prompt": "请从零开始做一套 Seed 轮融资路演 deck。产品是 AI 客服 SaaS，我有官网、logo 和一份产品白皮书。目标受众是投资人，想突出市场机会、增长数据和团队能力。",
      "should_trigger": true,
      "required_artifacts": [
        "brand_profile",
        "brief_summary",
        "research_dossier",
        "outline",
        "slide_spec",
        "page_plan",
        "style_profile",
        "delivery_manifest"
      ],
      "quality_expectations": [
        "明确governing thought并给出选项-结论逻辑",
        "证据引用可追溯",
        "不存在连续3页proof-wall"
      ]
    },
    {
      "id": "workflow-03-board-heavy-evidence",
      "category": "positive",
      "prompt": "把这份市场研究和财务数据整理成一套新的行业汇报 PPT，给董事会看。需要高密度信息，但不能乱，要保留来源。",
      "should_trigger": true,
      "required_artifacts": [
        "research_dossier",
        "outline",
        "slide_spec",
        "page_plan",
        "delivery_manifest"
      ],
      "quality_expectations": [
        "proof slide具有exhibit_intent和evidence_layer",
        "page_plan中proof_trace与slide_spec一致",
        "citations_mode与citations_placement一致"
      ]
    },
    {
      "id": "workflow-04-policy-briefing",
      "category": "positive",
      "prompt": "帮我做一套新的政策解读演示，主题是“2026 年 AI 合规要求变化”。受众是企业内部法务和产品团队，需要明确时间线、风险点和行动建议。",
      "should_trigger": true,
      "required_artifacts": [
        "research_dossier",
        "outline",
        "slide_spec",
        "page_plan"
      ],
      "quality_expectations": [
        "时间线相关页面使用timeline/process意图",
        "action页含decision意图或明确建议链"
      ]
    },
    {
      "id": "workflow-05-teaching-deck",
      "category": "positive",
      "prompt": "我要一套 45 分钟的教学课件，主题是“Transformer 基础入门”。受众是大三学生，希望讲清概念、流程和案例，风格简洁学术。",
      "should_trigger": true,
      "required_artifacts": [
        "brief_summary",
        "research_dossier",
        "outline",
        "slide_spec",
        "page_plan",
        "style_profile"
      ],
      "quality_expectations": [
        "narrative rhythm存在bridge或breathing",
        "页面不以高密度证明页连续堆叠"
      ]
    },
    {
      "id": "workflow-06-offline-source-pack",
      "category": "positive",
      "prompt": "我没有联网需求，只用我上传的白皮书和会议纪要做一套产品战略 deck。请从这些材料里完成研究、提纲和页面规划。",
      "should_trigger": true,
      "required_artifacts": [
        "brief_summary",
        "research_dossier",
        "outline",
        "slide_spec",
        "page_plan"
      ],
      "quality_expectations": [
        "research_dossier明确无联网限制",
        "不引用未提供来源的外部数据"
      ]
    },
    {
      "id": "workflow-07-svg-mode",
      "category": "positive",
      "prompt": "我需要直接拿 SVG 页面给设计同学继续加工，请按完整流程产出并包含可校验的 SVG 和预览。",
      "should_trigger": true,
      "required_artifacts": [
        "brand_profile",
        "brief_summary",
        "research_dossier",
        "outline",
        "slide_spec",
        "page_plan",
        "style_profile",
        "delivery_manifest"
      ],
      "required_validations": [
        "validate-artifacts passes",
        "validate-svg passes"
      ]
    },
    {
      "id": "workflow-08-brand-ready-assets",
      "category": "positive",
      "prompt": "做一套全新的融资 deck，并给我可交给外包设计师继续做的品牌化 handoff 资产包，默认先不要渲染 SVG。",
      "should_trigger": true,
      "required_artifacts": [
        "brand_profile",
        "brief_summary",
        "research_dossier",
        "outline",
        "slide_spec",
        "page_plan",
        "style_profile",
        "delivery_manifest"
      ],
      "quality_expectations": [
        "delivery mode为brand_ready_assets",
        "manifest中包含harness输入和逐页prompt映射"
      ]
    },
    {
      "id": "boundary-01-edit-existing-pptx",
      "category": "negative",
      "prompt": "帮我改一下这个现有 PPTX 的第 7 页，把排版调得更高级一点，标题短一点，其他内容别动。",
      "should_trigger": false,
      "expected_routing": "pptx-editing"
    },
    {
      "id": "boundary-02-review-existing-deck",
      "category": "negative",
      "prompt": "看看这套现成的路演 deck 有哪些逻辑问题，给我改进建议，不需要重做整套。",
      "should_trigger": false,
      "expected_routing": "deck-review"
    },
    {
      "id": "boundary-03-outline-only",
      "category": "negative",
      "prompt": "你先给我一个 10 页左右的 PPT 大纲就行，后面的页面结构和设计我自己做，不需要整套流程。",
      "should_trigger": false,
      "expected_routing": "light-outline"
    },
    {
      "id": "boundary-04-template-tweak",
      "category": "negative",
      "prompt": "我已经有公司模板了，你帮我把第 3 页和第 4 页重新排一下，内容基本不改，只是想更高级一点。",
      "should_trigger": false,
      "expected_routing": "template-editing"
    },
    {
      "id": "boundary-05-cover-only",
      "category": "negative",
      "prompt": "帮我做一个 keynote 风格的封面页，主题是“AI 助手时代”，不要整套 deck，就一页。",
      "should_trigger": false,
      "expected_routing": "single-slide-design"
    },
    {
      "id": "boundary-06-copy-polish",
      "category": "negative",
      "prompt": "我有一段演讲稿，帮我润色得更像发布会发言稿，不用做 deck。",
      "should_trigger": false,
      "expected_routing": "copy-polish"
    }
  ]
}
