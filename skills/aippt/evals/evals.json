    {
      "id": "scene-06-thesis-defense-positive",
      "category": "positive",
      "prompt": "请从零开始做一套毕业答辩 PPT，包含研究问题、文献缺口、方法、结果、贡献和未来工作。",
      "should_trigger": true,
      "scene_id": "thesis-defense",
